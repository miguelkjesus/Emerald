    <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets"/>

    <!-- Deploy the mod and ONLY its third-party dependencies to KSP's GameData.
         Stock KSP/Unity assemblies are excluded via <Private>False</Private> on their references,
         so they never reach $(OutputPath) and can't leak into GameData.
         netstandard.dll is a framework facade that a net472 build does not emit, so it is
         vendored in lib/ and copied explicitly. -->
    <Target Name="DeployToGameData" AfterTargets="Build">
        <PropertyGroup>
            <KspDir>$(HOME)/Library/Application Support/Steam/steamapps/common/Kerbal Space Program</KspDir>
            <EmeraldDir>$(KspDir)/GameData/Emerald</EmeraldDir>
            <!-- KSP's (Unity) Mono resolves the libmruby DllImport via its embed-runtime
                 fallback path; the Player.log shows it probing exactly this directory:
                 ".../KSP.app/Contents/Frameworks/MonoEmbedRuntime/osx/libmruby{,.dylib,.so,.bundle}".
                 The native lib is x86_64 (KSP runs x86_64), self-contained (only libSystem),
                 and is NOT under any signed resource set, so dropping it here is safe. -->
            <NativeDir>$(KspDir)/KSP.app/Contents/Frameworks/MonoEmbedRuntime/osx</NativeDir>
        </PropertyGroup>
        <ItemGroup>
            <Deploy Include="$(OutputPath)Emerald.*.dll" />
            <Deploy Include="$(OutputPath)ChibiRuby*.dll" />
            <Deploy Include="$(OutputPath)System.*.dll" />
            <Deploy Include="$(OutputPath)Microsoft.Bcl.*.dll" />
            <Deploy Include="$(OutputPath)Utf8StringInterpolation.dll" />
            <!-- Framework facades a net472 build does not propagate to this project's output.
                 All are vendored in lib/ and copied explicitly:
                 - netstandard.dll is never emitted.
                 - System.Runtime.CompilerServices.Unsafe.dll is resolved as a framework
                   assembly across the ProjectReference and dropped.
                 - System.ValueTuple.dll: ChibiRuby (netstandard2.0) references System.ValueTuple,
                   and the net461 netstandard.dll shim type-forwards it to a standalone
                   System.ValueTuple assembly. net472 keeps ValueTuple in mscorlib, so the build
                   never emits this DLL — without it KSP's Mono throws ReflectionTypeLoadException
                   ("Could not resolve type ... System.ValueTuple`n, netstandard, 2.0.0.0") and
                   ChibiRuby fails to load entirely. This is the matching companion to the
                   net461 netstandard.dll already vendored here. -->
            <Deploy Include="$(MSBuildThisFileDirectory)lib/netstandard.dll" />
            <Deploy Include="$(MSBuildThisFileDirectory)lib/System.Runtime.CompilerServices.Unsafe.dll" />
            <Deploy Include="$(MSBuildThisFileDirectory)lib/System.ValueTuple.dll" />
            <!-- Native MRuby compiler library (libmruby). Deployed to the embed-runtime path
                 (see NativeDir above), NOT GameData, because that is where Mono looks for it. -->
            <DeployNative Include="$(MSBuildThisFileDirectory)lib/libmruby.dylib" />
        </ItemGroup>
        <MakeDir Directories="$(EmeraldDir)" />
        <Copy SourceFiles="@(Deploy)" DestinationFolder="$(EmeraldDir)" SkipUnchangedFiles="true" />
        <MakeDir Directories="$(NativeDir)" />
        <Copy SourceFiles="@(DeployNative)" DestinationFolder="$(NativeDir)" SkipUnchangedFiles="true" />
        <Message Importance="high" Text="Emerald: deployed to $(EmeraldDir) -> @(Deploy)" />
        <Message Importance="high" Text="Emerald: deployed native lib to $(NativeDir) -> @(DeployNative)" />
    </Target>

