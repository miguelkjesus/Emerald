<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- GitHub Packages feed hosting the MiguelJesus.ChibiRuby.* packages.
         Auth is required even for public packages. Credentials are read from
         the GITHUB_USERNAME / GITHUB_TOKEN environment variables so no secrets
         are committed. The token needs the read:packages scope.
         e.g.  export GITHUB_USERNAME=<your-gh-user>
               export GITHUB_TOKEN=$(gh auth token) -->
    <add key="github-miguelkjesus" value="https://nuget.pkg.github.com/miguelkjesus/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-miguelkjesus>
      <add key="Username" value="%GITHUB_USERNAME%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github-miguelkjesus>
  </packageSourceCredentials>
</configuration>
